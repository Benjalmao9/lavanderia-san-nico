# ============================================================
#  PLANTILLA de variables de entorno del BACKEND (segura para versionar).
#
#  Este archivo SÍ puede subirse a Git: no contiene secretos reales, solo
#  placeholders. Para desarrollo local: copialo a un archivo llamado .env y
#  completá tus valores reales. El .env real está en .gitignore y NO se sube.
#
#      PowerShell:  Copy-Item .env.example .env
#
#  En PRODUCCIÓN (Railway / Render / etc.) NO se sube ningún .env: estas mismas
#  variables se cargan en el panel de la plataforma ("Environment Variables").
# ============================================================

# ------------------------------------------------------------
#  ENTORNO: "desarrollo" (por defecto) o "produccion".
#  En "produccion" se DESHABILITAN /docs, /redoc y /openapi.json (no exponer el
#  mapa de la API a anónimos). Dejalo en desarrollo localmente.
# ------------------------------------------------------------
ENTORNO=desarrollo

# ------------------------------------------------------------
#  BASE DE DATOS (MySQL)
#
#  Opción A (RECOMENDADA EN LA NUBE): una sola URL completa. La mayoría de los
#  proveedores de MySQL gestionado y de Railway/Render te dan esta cadena. Si
#  DATABASE_URL está definida, tiene PRIORIDAD y se ignoran las piezas DB_* de
#  abajo. Acepta 'mysql://...' o 'mysql+pymysql://...' (se normaliza el driver).
#      DATABASE_URL=mysql://usuario:clave@host:3306/nombre_base
#  (Dejala vacía/comentada en desarrollo local si usás las piezas DB_* de abajo.)
# DATABASE_URL=

#  Opción B (DESARROLLO LOCAL): piezas sueltas. Se usan solo si DATABASE_URL
#  NO está definida.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=lavanderia

# ------------------------------------------------------------
#  CLAVE SECRETA del JWT (firma de los tokens de login). CRÍTICA.
#  Generá una larga y aleatoria (mínimo 32 caracteres) y ponela acá en el .env
#  real / en las variables de la plataforma. NO uses este placeholder.
#  Generar una:  python -c "import secrets; print(secrets.token_urlsafe(64))"
#  Usá una clave DISTINTA en producción que en desarrollo.
# ------------------------------------------------------------
JWT_SECRET_KEY=genera_una_clave_larga_y_aleatoria_aqui

# ------------------------------------------------------------
#  Horas de vida del token JWT. Pasado ese plazo, hay que volver a iniciar
#  sesión. Por defecto 2 horas si no se define. Un plazo más corto limita el
#  daño si un token se filtra, a costa de tener que loguearse más seguido.
# ------------------------------------------------------------
JWT_EXPIRE_HOURS=2

# ------------------------------------------------------------
#  CORS: orígenes del frontend autorizados a llamar a la API (lista separada por
#  comas). En desarrollo, si lo dejás vacío, se permite el Vite local
#  (http://localhost:5173 y http://127.0.0.1:5173). En PRODUCCIÓN poné acá el
#  dominio real del frontend desplegado. NUNCA uses "*".
#      CORS_ORIGINS=https://mi-lavanderia.vercel.app
# ------------------------------------------------------------
# CORS_ORIGINS=

# ------------------------------------------------------------
#  CAPTCHA del login: Cloudflare Turnstile (SOLO se usa si ENTORNO=produccion).
#  Es la clave SECRETA (server-side) del par que te da Cloudflare al crear el
#  widget (dash.cloudflare.com -> Turnstile). La clave PÚBLICA (site key) va en
#  el frontend (frontend/.env.example -> VITE_TURNSTILE_SITE_KEY).
#  - En DESARROLLO no hace falta: el CAPTCHA se omite por completo (mismo
#    principio que /docs: los blindajes solo se activan donde importan).
#  - En PRODUCCIÓN es OBLIGATORIA: sin ella el servidor no arranca (fallo
#    ruidoso y temprano, igual que con JWT_SECRET_KEY).
# ------------------------------------------------------------
# TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
#  (Solo para el script crear_admin.py, que crea el administrador inicial.)
#  No las usa el servidor web; se leen al correr `python crear_admin.py`.
# ------------------------------------------------------------
# ADMIN_USUARIO=admin
# ADMIN_CONTRASENA=PonéUnaClaveSegura123
# ADMIN_NOMBRE_COMPLETO=Administrador del sistema
